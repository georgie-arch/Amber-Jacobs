# ============================================
# AMBER JACOBS — INDVSTRY CLVB
# Environment Configuration
# ============================================
# Copy this file to .env and fill in all values

# --- ANTHROPIC (Claude AI Brain) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- AMBER IDENTITY ---
AMBER_NAME=Amber Jacobs
AMBER_EMAIL=amber@indvstryclvb.com
AMBER_TITLE=Community Manager

# --- APPROVAL WORKFLOW ---
# Set to true to allow Amber to send messages without approval
AUTO_SEND=false
# George's email for approval notifications
FOUNDER_EMAIL=george@indvstryclvb.com
FOUNDER_PHONE=+447XXXXXXXXX

# --- GMAIL ---
# Get credentials from Google Cloud Console
# Enable: Gmail API
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token
GMAIL_USER=amber@indvstryclvb.com

# --- LINKEDIN ---
# Option A: Apify (recommended - handles anti-scraping)
# Get API key from apify.com
APIFY_API_KEY=your_apify_api_key
LINKEDIN_ACTOR_ID=dev_fusion/linkedin-profile-scraper

# Option B: RapidAPI LinkedIn endpoint
RAPIDAPI_KEY=your_rapidapi_key
RAPIDAPI_HOST=linkedin-data-api.p.rapidapi.com

# Your LinkedIn session cookie (for messaging - requires manual login)
LINKEDIN_LI_AT_COOKIE=your_linkedin_session_cookie
LINKEDIN_CSRF_TOKEN=your_linkedin_csrf_token
LINKEDIN_PROFILE_URL=https://linkedin.com/in/amber-jacobs-indvstryclvb

# --- INSTAGRAM ---
# Get from Meta Business Suite / Meta Developers
# Requires: Instagram Business Account + Facebook Page
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_id
# Webhook verify token (you choose this)
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=amber_indvstryclvb_webhook_2024

# --- WHATSAPP BUSINESS ---
# Option A: Twilio (easiest setup)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Option B: Meta WhatsApp Business API (direct)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=amber_whatsapp_webhook_2024
META_WHATSAPP_BUSINESS_ID=your_business_id

# --- TELEGRAM ---
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_USERNAME=AmberIndvstryClvbBot
# Your Telegram user ID (for admin notifications)
TELEGRAM_ADMIN_ID=your_telegram_user_id

# --- DATABASE ---
DB_PATH=./amber_memory.db

# --- SERVER ---
PORT=3000
WEBHOOK_BASE_URL=https://your-server-domain.com

# --- INDVSTRY CLVB SETTINGS ---
CLUB_NAME=Indvstry Clvb
CLUB_WEBSITE=https://indvstryclvb.com
CLUB_APPLICATION_URL=https://indvstryclvb.com/apply
MEMBERSHIP_PRICE=£XX/month
# Days to wait before following up with a lead
LEAD_FOLLOWUP_DAYS=3
# Days after onboarding to send check-in
MEMBER_CHECKIN_DAYS=7
