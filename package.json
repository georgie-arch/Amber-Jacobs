{
  "name": "amber-jacobs-agent",
  "version": "1.0.0",
  "description": "Amber Jacobs — AI Community Manager for Indvstry Clvb",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "start:email": "ts-node src/index.ts --service=email",
    "start:telegram": "ts-node src/index.ts --service=telegram",
    "start:whatsapp": "ts-node src/index.ts --service=whatsapp",
    "start:instagram": "ts-node src/index.ts --service=instagram",
    "db:setup": "ts-node src/database/migrations.ts",
    "tasks:run": "ts-node src/tools/scheduler.ts --run-now",
    "memory:view": "ts-node src/utils/memory-viewer.ts",
    "dev": "nodemon --exec 'ts-node src/index.ts'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "axios": "^1.6.8",
    "better-sqlite3": "^12.6.2",
    "body-parser": "^1.20.2",
    "date-fns": "^3.4.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "googleapis": "^140.0.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.9",
    "telegraf": "^4.16.3",
    "twilio": "^5.0.4",
    "winston": "^3.12.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.28",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.2"
  }
}
